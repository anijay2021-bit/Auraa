{
  "expo": {
    "name": "Auraa",
    "slug": "auraa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "auraa",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDF7F2"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.auraa.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FDF7F2"
      },
      "package": "com.auraa.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      [
        "expo-image-picker",
        {
          "photosPermission": "Auraa needs access to your photos to analyze your coloring.",
          "cameraPermission": "Auraa needs camera access to capture your photo for color analysis."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
